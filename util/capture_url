#!/usr/bin/python
"""Capture one browser URL with CDP, including network bodies and page views."""

from __future__ import annotations

import argparse
from pathlib import Path
import sys

from epitome_lib.capture import capture_url, default_capture_dir


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Capture one URL with cdp network-log and bounded scrolling."
    )
    parser.add_argument("url")
    parser.add_argument("--output", type=Path)
    parser.add_argument("--port", type=int, default=2103)
    parser.add_argument("--max-scrolls", type=int, default=40)
    parser.add_argument("--max-seconds", type=float, default=90)
    parser.add_argument("--settle-seconds", type=float, default=2)
    parser.add_argument("--keep-tab", action="store_true")
    return parser.parse_args()


def main() -> int:
    args = parse_args()
    output = args.output or default_capture_dir(args.url)
    try:
        manifest = capture_url(
            args.url,
            output,
            port=args.port,
            max_scrolls=args.max_scrolls,
            max_seconds=args.max_seconds,
            settle_seconds=args.settle_seconds,
            keep_tab=args.keep_tab,
        )
    except (RuntimeError, ValueError) as error:
        print(f"capture_url: {error}", file=sys.stderr)
        return 1
    summary = manifest["network_summary"]
    print(
        f"Captured {summary['requests']} responses "
        f"({summary['response_bytes']} body bytes) to {output}"
    )
    return 0


if __name__ == "__main__":
    raise SystemExit(main())

