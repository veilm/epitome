#!/usr/bin/python
"""Sequentially capture a bounded list of URLs with progress recorded as JSONL."""

from __future__ import annotations

import argparse
import json
from pathlib import Path
import sys
import time

from epitome_lib.capture import capture_url, url_slug, validate_url


def load_urls(positional: list[str], url_file: Path | None) -> list[str]:
    values = list(positional)
    if url_file:
        values.extend(
            line.strip()
            for line in url_file.read_text(encoding="utf-8").splitlines()
            if line.strip() and not line.lstrip().startswith("#")
        )
    seen: set[str] = set()
    result = []
    for value in values:
        validate_url(value)
        if value not in seen:
            seen.add(value)
            result.append(value)
    return result


def append_event(path: Path, event: dict) -> None:
    with path.open("a", encoding="utf-8") as stream:
        stream.write(json.dumps(event, ensure_ascii=False, sort_keys=True) + "\n")


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser()
    parser.add_argument("urls", nargs="*")
    parser.add_argument("--url-file", type=Path)
    parser.add_argument("--output-root", type=Path)
    parser.add_argument(
        "--max-urls",
        type=int,
        default=10,
        help="refuse larger inputs unless this limit is explicitly raised",
    )
    parser.add_argument("--port", type=int, default=2103)
    parser.add_argument("--max-scrolls", type=int, default=40)
    parser.add_argument("--max-seconds", type=float, default=90)
    parser.add_argument("--settle-seconds", type=float, default=2)
    parser.add_argument(
        "--delay-seconds",
        type=float,
        default=10,
        help="pause between page captures (default: 10 seconds)",
    )
    parser.add_argument("--stop-on-error", action="store_true")
    return parser.parse_args()


def main() -> int:
    args = parse_args()
    try:
        urls = load_urls(args.urls, args.url_file)
    except (OSError, ValueError) as error:
        print(f"capture_urls: {error}", file=sys.stderr)
        return 2
    if not urls:
        print("capture_urls: no URLs supplied", file=sys.stderr)
        return 2
    if args.max_urls < 1:
        print("capture_urls: --max-urls must be positive", file=sys.stderr)
        return 2
    if args.delay_seconds < 0:
        print("capture_urls: --delay-seconds must be non-negative", file=sys.stderr)
        return 2
    if len(urls) > args.max_urls:
        print(
            f"capture_urls: refusing {len(urls)} URLs; "
            f"raise --max-urls from {args.max_urls} explicitly",
            file=sys.stderr,
        )
        return 2

    run_timestamp = int(time.time())
    root = args.output_root or Path("data/crawls") / str(run_timestamp)
    pages = root / "pages"
    pages.mkdir(parents=True, exist_ok=False)
    progress = root / "progress.jsonl"
    failures = 0
    append_event(
        progress,
        {"event": "start", "timestamp": run_timestamp, "urls": urls},
    )
    for index, url in enumerate(urls, start=1):
        output = pages / f"{index:06d}-{url_slug(url)}"
        append_event(
            progress,
            {"event": "capture_start", "index": index, "url": url},
        )
        print(f"[{index}/{len(urls)}] Capturing {url}", flush=True)
        try:
            manifest = capture_url(
                url,
                output,
                port=args.port,
                max_scrolls=args.max_scrolls,
                max_seconds=args.max_seconds,
                settle_seconds=args.settle_seconds,
            )
            append_event(
                progress,
                {
                    "event": "capture_complete",
                    "index": index,
                    "url": url,
                    "network_summary": manifest["network_summary"],
                },
            )
        except Exception as error:
            failures += 1
            append_event(
                progress,
                {
                    "event": "capture_error",
                    "index": index,
                    "url": url,
                    "error": f"{type(error).__name__}: {error}",
                },
            )
            print(f"capture_urls: {url}: {error}", file=sys.stderr)
            if args.stop_on_error:
                break
        if index < len(urls) and args.delay_seconds:
            append_event(
                progress,
                {
                    "event": "delay",
                    "after_index": index,
                    "seconds": args.delay_seconds,
                },
            )
            print(
                f"Waiting {args.delay_seconds:g} seconds before the next article",
                flush=True,
            )
            time.sleep(args.delay_seconds)
    append_event(
        progress,
        {"event": "finish", "timestamp": int(time.time()), "failures": failures},
    )
    print(f"Capture run written to {root} ({failures} failures)")
    return min(failures, 1)


if __name__ == "__main__":
    raise SystemExit(main())
