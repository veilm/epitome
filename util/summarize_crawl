#!/usr/bin/python
"""Print an aggregate report for a capture_urls crawl directory."""

from __future__ import annotations

import argparse
import json
from pathlib import Path

from epitome_lib.capture import summarize_crawl


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("crawl", type=Path)
    args = parser.parse_args()
    print(json.dumps(summarize_crawl(args.crawl), indent=2, sort_keys=True))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
