#!/usr/bin/python
"""List URLs from a sitemap or bounded sitemap index traversal."""

from __future__ import annotations

import argparse
from collections import deque
from pathlib import Path
import sys
from urllib.request import Request, urlopen

sys.path.insert(0, str(Path(__file__).resolve().parent.parent))

from research.sitemap import locations


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("sitemap")
    parser.add_argument("--max-sitemaps", type=int, default=50)
    parser.add_argument("--max-urls", type=int, default=20_000)
    parser.add_argument("--timeout", type=float, default=20)
    args = parser.parse_args()

    queue = deque([args.sitemap])
    seen_sitemaps: set[str] = set()
    seen_urls: set[str] = set()
    while queue:
        sitemap = queue.popleft()
        if sitemap in seen_sitemaps:
            continue
        if len(seen_sitemaps) >= args.max_sitemaps:
            print("list_sitemap_urls: sitemap limit reached", file=sys.stderr)
            return 2
        seen_sitemaps.add(sitemap)
        request = Request(sitemap, headers={"User-Agent": "epitome-research/0"})
        try:
            with urlopen(request, timeout=args.timeout) as response:
                child_sitemaps, urls = locations(response.read())
        except Exception as error:
            print(f"list_sitemap_urls: {sitemap}: {error}", file=sys.stderr)
            return 1
        queue.extend(child_sitemaps)
        for url in urls:
            if url in seen_urls:
                continue
            if len(seen_urls) >= args.max_urls:
                print("list_sitemap_urls: URL limit reached", file=sys.stderr)
                return 2
            seen_urls.add(url)
            print(url)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
